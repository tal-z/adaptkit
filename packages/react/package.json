{
  "name": "@adaptkit/react",
  "version": "0.1.0",
  "description": "React bindings for AdaptKit",
  "license": "Elastic-2.0",
  "author": "AdaptKit Contributors",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@adaptkit/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  }
}
